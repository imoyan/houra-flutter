{
  "name": "@houra/protocol-core-wasm-facade",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript lab facade for the Houra Rust WASM protocol core.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/imoyan/houra-labs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imoyan/houra-labs.git",
    "directory": "ts-protocol-core-wasm"
  },
  "bugs": {
    "url": "https://github.com/imoyan/houra-labs/issues"
  },
  "keywords": [
    "houra",
    "matrix",
    "protocol",
    "wasm",
    "typescript"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "benchmark": "npm run build && node benchmark.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run build",
    "test": "npm run build && node --test test/*.test.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
